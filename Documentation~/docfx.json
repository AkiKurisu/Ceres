{
    "metadata": [
        {
            "src": [
                {
                    "src": "..",
                    "files": [
                        "Runtime/**/*.cs",
                        "Editor/**/*.cs"
                    ]
                }
            ],
            "globalNamespaceId": "Global",
            "filter": "filterConfig.yml",
            "dest": "api"
        }
    ],
    "build": {
        "template": [
            "default",
            "modern",
            "templates/ceres"
        ],
        "globalMetadata": {
            "_appName": "Ceres",
            "_appTitle": "Ceres Documentation",
            "_appLogoPath": "resources/Images/ceres_icon.png",
            "_appFaviconPath": "resources/Images/ceres_icon.png",
            "_appFooter": "Copyright © 2025 <b>AkiKurisu</b> · Powerful visual scripting toolkit for Unity · Generated with <b>DocFX</b>",
            "_enableSearch": true,
            "_disableContribution": false,
            "_gitContribute": {
                "repo": "https://github.com/AkiKurisu/Ceres",
                "branch": "main"
            }
        },
        "content": [
            {
                "files": [
                    "toc.yml",
                    "index.md"
                ]
            },
            {
                "src": "api",
                "files": [
                    "*.yml"
                ],
                "dest": "api"
            },
            {
                "src": "docs",
                "files": [
                    "toc.yml",
                    "*.md"
                ],
                "dest": "docs"
            }
        ],
        "resource": [
            {
                "files": [
                    "resources/**/*"
                ]
            }
        ],
        "sitemap": {
            "baseUrl": "https://AkiKurisu.github.io/Ceres",
            "changefreq": "weekly",
            "fileOptions": {
                "api/*": {
                    "changefreq": "weekly"
                }
            }
        },
        "xref": [
            "https://normanderwan.github.io/UnityXrefMaps/xrefmap.yml"
        ],
        "xrefService": [
            "https://xref.docs.microsoft.com/query?uid={uid}"
        ],
        "dest": "../site~"
    }
}